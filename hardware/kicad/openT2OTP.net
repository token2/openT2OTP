(export (version "E")
  (design (source "openT2OTP.kicad_sch") (tool "openT2OTP_gen"))
  (components
    (comp (ref "U1") (value "SAM L22 (ATSAML22N18A)"))
    (comp (ref "DS1") (value "6-digit 7-seg LCD"))
    (comp (ref "U2") (value "NFC front-end (ST25R3916)"))
    (comp (ref "U3") (value "Secure element (SE050)"))
    (comp (ref "Y1") (value "32.768 kHz"))
    (comp (ref "L1") (value "NFC antenna loop"))
    (comp (ref "C1") (value "tune (C0G)"))
    (comp (ref "C2") (value "tune (C0G)"))
    (comp (ref "C3") (value "LCD bias"))
    (comp (ref "C7") (value "100nF"))
    (comp (ref "C9") (value "1uF"))
    (comp (ref "R1") (value "10k"))
    (comp (ref "R2") (value "10k"))
    (comp (ref "SW1") (value "Power/show"))
    (comp (ref "BT1") (value "CR2032"))
    (comp (ref "J1") (value "SWD"))
  )
  (nets
